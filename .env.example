# ---------------------------------------------------------------------------
# Reverse Lookup — provider API keys. Copy to `.env.local` and fill in.
# All keys are used server-side only and never exposed to the browser.
# ---------------------------------------------------------------------------

# Phone lookup — https://numverify.com  (free tier: 100 lookups/month)
NUMVERIFY_API_KEY=

# Phone lookup fallback — https://www.abstractapi.com/api/phone-validation-api
ABSTRACT_PHONE_API_KEY=

# Email verification — primary: https://www.abstractapi.com/api/email-verification-validation-api
# On 429 (rate limit), automatically retries once after 1.5s then falls back to Mailboxlayer.
ABSTRACT_EMAIL_API_KEY=

# Email verification fallback — https://mailboxlayer.com (free tier: 100/month, no per-second limit)
MAILBOXLAYER_API_KEY=

# ---------------------------------------------------------------------------
# Person enrichment (biodata) — both providers run in parallel; results merged.
#
# PDL (People Data Labs) — https://www.peopledatalabs.com
# Strong on professional profiles, LinkedIn data, job/company info.
# Free tier: 100 calls/month — sign up at app.peopledatalabs.com
PDL_API_KEY=

# ---------------------------------------------------------------------------
# Breach lookup — https://haveibeenpwned.com/API/Key
# Shows which data breaches contain the searched email + paste count.
# Plans from $3.50/month — the most impactful enrichment for email lookups.
# ---------------------------------------------------------------------------
HIBP_API_KEY=
#
# Hunter.io — https://hunter.io (sign up free with Google, 25 enrichments/month)
# Returns name, job title, company, location, LinkedIn and Twitter from an email.
# Only works for email lookups (not phone).
HUNTER_API_KEY=

# ---------------------------------------------------------------------------
# Name / people search (name-based lookup).
# The app ships with a pluggable provider. Set PEOPLE_PROVIDER_URL to a JSON
# endpoint you control, or leave blank to show the "not configured" state.
# ---------------------------------------------------------------------------
PEOPLE_PROVIDER_URL=
PEOPLE_PROVIDER_API_KEY=
