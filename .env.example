# ---------------------------------------------------------------------------
# Reverse Lookup — provider API keys. Copy to `.env.local` and fill in.
# All keys are used server-side only and never exposed to the browser.
# ---------------------------------------------------------------------------

# Phone lookup — https://numverify.com  (free tier: 100 lookups/month)
NUMVERIFY_API_KEY=

# Phone lookup fallback — https://www.abstractapi.com/api/phone-validation-api
ABSTRACT_PHONE_API_KEY=

# Email verification — https://www.abstractapi.com/api/email-verification-validation-api
ABSTRACT_EMAIL_API_KEY=

# ---------------------------------------------------------------------------
# Name / people search.
# There is no reliable *free* people-search API; owner-identity data is paid
# and regulated (see README). The app ships with a pluggable provider that
# calls a JSON HTTP endpoint you control. Configure it here, or leave blank
# to show the "provider not configured" state.
#
# PEOPLE_PROVIDER_URL should accept ?name=<full name>&state=<optional> and
# return JSON: { "results": [ { "name", "age", "location", "phones":[],
# "emails":[], "relatives":[] } ] }
# ---------------------------------------------------------------------------
PEOPLE_PROVIDER_URL=
PEOPLE_PROVIDER_API_KEY=
